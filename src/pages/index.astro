---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>Ian Research</h1>
        <p>
          Personal research and essays on equities, macro, technology,
          and business strategy.
        </p>
      </section>

      <section>
        <h2>Research Focus</h2>
        <ul>
          <li>AI infrastructure and application-layer economics</li>
          <li>Semiconductors, energy, and industrial supply chains</li>
          <li>Macro policy, capital cycles, and public equities</li>
        </ul>
      </section>

      <section>
        <h2>Latest</h2>
        <p>
          Read the latest research note on
          <a href="/research/ai-infra-power-demand/">AI infrastructure and application ROI</a>.
        </p>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 5rem 1.5rem;
  }

  .hero {
    margin-bottom: 4rem;
  }

  h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
  }

  p,
  li {
    font-size: 1.1rem;
    line-height: 1.7;
  }

  section {
    margin-bottom: 3rem;
  }
</style>