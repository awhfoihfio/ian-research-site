---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
  <nav>
    <h2>
      <a href="/">{SITE_TITLE}</a>
    </h2>

    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/research">Research</HeaderLink>
      <HeaderLink href="/essays">Essays</HeaderLink>
      <HeaderLink href="/notes">Notes</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <HeaderLink href="/disclaimer">Disclaimer</HeaderLink>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: white;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
  }

  h2 {
    margin: 0;
    font-size: 1em;
  }

  h2 a {
    color: rgb(var(--black));
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .internal-links {
    display: flex;
    gap: 1.25rem;
  }
</style>